@app.route('/documents/archive')
@login_required
def archive_documents():
    """عرض أرشيف الوثائق"""
    page = request.args.get('page', 1, type=int)
    search = request.args.get('search', '')

    query = Document.query

    if search:
        query = query.filter(
            (Document.title.contains(search)) |
            (Document.tags.contains(search))
        )

    if current_user.role != 'admin':
        query = query.filter(
            (Document.is_public == True) |
            (Document.author_id == current_user.id) |
            (Document.department == current_user.department)
        )

    documents = query.order_by(Document.created_at.desc()).paginate(page=page, per_page=10)

    return render_template_string('''
